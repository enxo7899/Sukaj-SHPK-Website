#main-sidebar-navigation {
  height: 100%;
  max-height: 410px !important;
}


/* by Paschalis */

/* contact info boxes in footer*/

.contact-footer-sidebar-wrapper>section {
	margin-top:2em;
}
.block-heading-small {
	margin-bottom:1em;
}
.contact-footer-sidebar-wrapper {
	padding-top:10px;
}

/* main sidebar Height */
#main-sidebar-navigation {
 height: 100%;
	min-height:510px;
	margin-bottom: 0 !important;
}


.sidebar-search {
	margin-top: 0 !important;
	
	
}

.sidebar-search .input-group {
	background-color:white;
}

.form-control {
	color: black !important;	
}


.input-group-btn .btn {
	background-color: whitesmoke!important;
	border-left: 2px solid black;
	
}

/* hide searchbar */
@media screen and  (max-height:885px ){
		
	.sidebar-search {
		display:none;
	}
}


/* PAGINATION IN MAIN BLOG PAGE */
.pagination {
    width: 100%;
	}

.pagination .nav-links a, .pagination .nav-links .current{
    padding:5px 11px;
    color:#262626;
    border-radius: 4px;
    font-weight:700;
		border: 1px solid #CBCACA;
		transition: all 0.15s;
		margin-right: 4px;
}

.pagination .nav-links .current{
  background-color:#262626;
	color: white;
	cursor: default;
}

.nav-links a:hover {
	color:black;
	border: 1px solid #A1A1A1;
	
}

.nav-links {
	text-align: center;
}

/* PAGINATION IN SINGLE BLOG PAGE */
	.flex-container-pagination {
		display: flex;
    flex-direction: row;
    justify-content: space-between;
    font-size: 1em;
   
}
.previous-post-left {
    display: flex;
    min-height: 60px;
    width: 50%;
    border-right: 1px solid grey;
   /* vertical-align: center;*/
    align-content: space-around;
    gap: 5px;
}
.next-post-right {
    display: flex;
    min-height: 60px;
    width: 50%;
   /* vertical-align: center;*/
    align-content: space-around; 
    justify-content: flex-end;
		text-align: right;
}
.previous_post_Pr a, .next_post_Nxt a {
	color: #0057C6;
}

.previous_post_thumbnail{
	max-width: 80px;
	max-height: 80px;
	margin-top: 8px;
	border-radius: 4px;
	overflow: hidden;
}
.next_post_thumbnail{
	max-width: 80px;
	max-height: 80px;
	margin-top: 8px;
	border-radius: 4px;
	overflow: hidden;
}

/* main menu horizontal scroller */
.scroller-wrapper
{
	display:none;
}

 /* technical-leaflets-block at left sidebar   */

.technical-leaflets-block {
	bottom:0 ;
}

/* technical leaflets page bottom*/
.fixed-documents-wrapper {
	bottom: 0;
	height: 4em;
	
}

/*MAIN BLOG DESIGN IMPROVEMENTS*/
body.blog .articles-container>article.post .post-wrapper {
    border-radius: 4px;
    overflow: hidden;
}
.single_post_view_date{
	color: #b9b9b9;
}
.single_post_view_date {
    color: #ffffff;
    position: absolute;
    top: -12px;
    right: 10px;
    background: red;
    padding: 2px 8px;
}


/* MAIN BLOG CHANGE FEATURED IMAGE SIZE */

/*
.entry-content img {
	max-width: 70%;
}

*/

/*PRODUCT TABLE FIX color in product code*/
td.palaplast-color-box span.colored-value {

    white-space: nowrap;
    width: auto;
}

/* CONTACT FORMS FIX*/
#palaplast-contact-us-form .material-label-move {
    transform: translateY(-22px);
}
#palaplast-contact-us-form select{
	text-transform: none; 
}


.wpcf7-form-control {
  text-transform: none !important;
}


