		filter: grayscale(20%);
    transition: all 0.2s ease;
  	border-radius: 2px!important;
	  
}

.wp-image-25473:hover {
    filter: grayscale(0%);
	  border-radius: 6px!important;
	  display: block!important;
}
/* End Button Συμμετοχή greek */
/* Start Social Media icons */

.footer-wrapper a {
    color: #000!important;
}


li.f-us{
	font-size: 18px;
}


.footer-social ul li{
    line-height: 0px;
	  border-right: 0px solid #666;
}
i{
font-size: 20px;	
}


#ig-icon{
	margin-left: -5px;
	margin-bottom: 12px;
	width: 24px;
	opacity: 1;
	transition: all .2s;
}
#ig-icon:hover, #ig-icon:visited{
	
	opacity: 1;

}

#icon-linkedin{
	width: 24px;
	margin-bottom: 12px;
}
@media (max-width: 580px) {
  #icon-linkedin{
	width: 18px;
	margin-bottom: 4px;
	margin-left: -56px;
}
}


/* End Social Media icons */

/* Button Συμμετοχή english */
.wp-image-25938 {
		filter: grayscale(20%);
    transition: all 0.2s ease;
  	border-radius: 2px!important;
	  
}

.wp-image-25938:hover {
    filter: grayscale(0%);
	  border-radius: 6px!important;
	  display: block!important;
}
/* End Button Συμμετοχή english */

/* Pinakas ΑΡΔΕΥΤΙΚΗ ΠΕΡΙΟΔΟΣ 2020 */
.pinakas{
	width: 90%;
  border-collapse: collapse;
  border-spacing: 0px;
	cursor: pointer;
} 
.a_prasino {
  background: #E9FFE9;
}
.s_prasino {
  background: #B3F2B4;
}
.pinakas td {
	border: 1px solid white;
}



/* End ΑΡΔΕΥΤΙΚΗ ΠΕΡΙΟΔΟΣ 2020 */

/*Youtube Responsive Video embed 56.25% */
.video-containter{
	width: 100%;
	position: relative;
	padding-bottom: 56.25%;
	height: 0;
}
.video-containter iframe{
	position: absolute;
	top: 0;
	left: 0;
	width: 80%;
	height: 80%;
}
/*End Youtube Responsive Video embed*/

/* Home Page background */

.homepage-header-wrapper {
   background: url(https://palaplast.gr/wp-content/uploads//2020/09/Website-BG-3.jpg)!important;       	  background-size: cover!important;	
   background-position: 50%!important;
}

/* End Home Page background */

